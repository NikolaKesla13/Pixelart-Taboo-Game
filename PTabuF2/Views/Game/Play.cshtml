@model PTabuF2.Models.Card
@using PTabuF2.Models
@using System.Text.Json
@{
    ViewData["Title"] = "Play";
    var sessionJson = Context.Session.GetString("GameSession");
    var session = sessionJson != null ? JsonSerializer.Deserialize<GameSession>(sessionJson) : new GameSession();
}

<head>
    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #9C59FF; /* Arka plan mor */
            color: white;
            font-family: 'VT323', monospace;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .game-container {
            text-align: center;
            width: 100%;
            max-width: 800px;
        }

        .card-box {
            background-color: white;
            color: black;
            border: 5px solid black;
            border-radius: 20px;
            padding: 30px;
            margin: 20px auto;
            width: 400px;
            box-shadow: 15px 15px 0 rgba(0,0,0,0.2);
        }

        .target-word {
            font-size: 60px;
            border-bottom: 5px solid black;
            margin-bottom: 20px;
            font-weight: bold;
            color: #FF5E5E;
        }

        .forbidden-words {
            font-size: 35px;
            line-height: 1.5;
            color: #333;
        }

        .controls {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
        }

        .control-btn {
            font-family: 'VT323';
            font-size: 30px;
            padding: 15px 40px;
            border: 4px solid black;
            color: white;
            cursor: pointer;
            text-transform: uppercase;
            box-shadow: 5px 5px 0 black;
            transition: transform 0.1s;
        }

            .control-btn:active {
                transform: translate(2px, 2px);
                box-shadow: 3px 3px 0 black;
            }
    </style>
</head>

<body>

    <div class="game-container">

        <div style="margin-bottom:20px;">
            @if (session.CurrentTeam == 1)
            {
                <span style="background-color:#FFD700; color:black; padding:10px 30px; font-size:40px; border:4px solid black; font-weight:bold; box-shadow: 5px 5px 0 black;">
                    @session.Team1Name IS PLAYING
                </span>
            }
            else
            {
                <span style="background-color:#FF5E5E; color:white; padding:10px 30px; font-size:40px; border:4px solid black; font-weight:bold; box-shadow: 5px 5px 0 black;">
                    @session.Team2Name IS PLAYING
                </span>
            }
        </div>

        <div style="font-size:30px; margin-bottom:10px; text-shadow: 2px 2px 0 black;">
            <span id="timer" style="color:#FFD700;">TIME: @session.RemainingTime</span>
            &nbsp;|&nbsp;
            <span>SCORE: @(session.CurrentTeam == 1 ? session.Team1Score : session.Team2Score)</span>
            <span style="color:#ddd; font-size:24px;"> / TARGET: @session.TargetScore</span>
        </div>

        <div class="card-box">
            <div class="target-word">
                @Model.TargetWord

                @if (!string.IsNullOrEmpty(Model.Tag))
                {
                    <span style="font-size:30px; color:#555; vertical-align:middle;">
                        (@Model.Tag)
                    </span>
                }
                </div>
            <div class="forbidden-words">
                <div>@Model.ForbiddenWord1</div>
                <div>@Model.ForbiddenWord2</div>
                <div>@Model.ForbiddenWord3</div>
                <div>@Model.ForbiddenWord4</div>
                <div>@Model.ForbiddenWord5</div>
            </div>
        </div>

        <div class="controls">

            <button type="button" class="control-btn" style="background-color:#FF5E5E;"
                    onclick="playAndSubmit('Taboo')">
                TABOO
            </button>

            @if (session.PassRights > 0)
            {
                <button type="button" class="control-btn" style="background-color:#FFA500; color:black;"
                        onclick="playAndSubmit('Pass')">
                    PASS (@session.PassRights)
                </button>
            }
            else
            {
                <button type="button" class="control-btn" style="background-color:gray; cursor:not-allowed;">PASS (0)</button>
            }

            <button type="button" class="control-btn" style="background-color:#4CAF50;"
                    onclick="playAndSubmit('Correct')">
                CORRECT
            </button>

        </div>

    </div>
    <form id="formTaboo" asp-action="MakeMove" asp-route-move="taboo" method="post" style="display:none;"></form>
    <form id="formPass" asp-action="MakeMove" asp-route-move="pass" method="post" style="display:none;"></form>
    <form id="formCorrect" asp-action="MakeMove" asp-route-move="correct" method="post" style="display:none;"></form>

    <audio id="audioCorrect" src="~/audio/correct.mp3"></audio>
    <audio id="audioTaboo" src="~/audio/taboo.mp3"></audio>
    <audio id="audioPass" src="~/audio/pass.mp3"></audio>

    <script>
        // SAYAÇ KODU
        var timeLeft = localStorage.getItem("gameTime") ? parseInt(localStorage.getItem("gameTime")) : @session.RemainingTime;
        document.getElementById("timer").innerText = "TIME: " + timeLeft;

        var timerInterval = setInterval(function() {
            timeLeft--;
            document.getElementById("timer").innerText = "TIME: " + timeLeft;
            localStorage.setItem("gameTime", timeLeft);

            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                window.location.href = "/Game/TurnOver";
            }
        }, 1000);

        // SES VE GECİKMELİ GÖNDERİM KODU
        function playAndSubmit(type) {
            // 1. Sesi Çal
            var audio = document.getElementById("audio" + type);
            if (audio) {
                audio.play().catch(e => console.log("Ses hatası: " + e));
            }

            // 2. Buton animasyonu (Ufak bir görsel tepki)
            // 700ms bekleyip formu gönder
            setTimeout(function() {
                document.getElementById("form" + type).submit();
            }, 700);
        }
    </script>
</body>